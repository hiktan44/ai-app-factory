# ============================================================
# AI App Factory - Ortam Değişkenleri
# ============================================================
# Bu dosyayı .env.local olarak kopyalayın ve değerleri doldurun:
#   cp .env.example .env.local
# ============================================================

# ---- Zorunlu ----

# Gemini API Key (idea generation & product spec)
# https://aistudio.google.com/apikey adresinden alın
GEMINI_API_KEY=

# ---- Supabase Auth & Database ----

# Supabase Project URL
# Supabase projenizin Settings > API bölümünden bulabilirsiniz
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Key (Public)
# Supabase projenizin Settings > API bölümünden "anon public" key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role Key (Server-side only!)
# DİKKAT: Bu key RLS'yi bypass eder. Asla client-side kodda kullanmayın.
# Supabase projenizin Settings > API bölümünden "service_role" key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Auth Sistemini Devre Dışı Bırakma (true ise login bypass edilir, herkes super_admin olur)
NEXT_PUBLIC_DISABLE_AUTH=true

# ---- Pipeline için Zorunlu (opsiyonel sadece web UI için) ----

# Anthropic API Key (Claude CLI - orchestrator.sh için)
# ANTHROPIC_API_KEY=

# Claude Max Planı OAuth Token (Gereksiz API maliyetlerinden kaçınmak için)
# CLAUDE_CODE_OAUTH_TOKEN=

# ---- İsteğe Bağlı ----

# GitHub entegrasyonu
# GITHUB_TOKEN=
# GITHUB_ORG=

# Coolify deploy entegrasyonu
# COOLIFY_API_URL=https://your-coolify-instance.com
# COOLIFY_API_TOKEN=

# Vercel deploy entegrasyonu (Vercel'e deploy için)
# VERCEL_TOKEN=
# VERCEL_TEAM_ID=

# ---- Veritabanı (Kalıcılık için Önerilir) ----

# PostgreSQL bağlantı URL'si — run durumları ve kuyruk buraya kaydedilir
# Coolify'da otomatik oluşturulan DB için bu değeri Coolify panelinden alın
# DATABASE_URL=postgres://factory:password@hostname:5432/factory

# ---- Sistem ----

# Proje kök dizini (orchestrator.sh ve runs/ dizininin bulunduğu yer)
# Lokal: ..   Docker: /factory
PROJECT_ROOT=..

# Port (varsayılan: 3000)
PORT=3000

# Kaldığı yerden devam etme (1: en son yarıda kalan run'dan devam eder, 0: yeni run oluşturur)
RESUME_LAST=0
